                           <pdfaType:namespaceURI>http://ns.adobe.com/xap/1.0/sType/Font#</pdfaType:namespaceURI>
                           <pdfaType:prefix>stFnt</pdfaType:prefix>
                           <pdfaType:type>Font</pdfaType:type>
                        </rdf:li>
                     </rdf:Seq>
                  </pdfaSchema:valueType>
               </rdf:li>
               <rdf:li rdf:parseType="Resource">
                  <pdfaSchema:namespaceURI>http://ns.adobe.com/pdfx/1.3/</pdfaSchema:namespaceURI>
